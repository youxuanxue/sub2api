{
  "version": 1,
  "rationale": "Static anchors for Claude Code geo-stego + prompt-surface normalizers.",
  "cc_version": "2.1.199",
  "binary_default_path": "~/.local/share/claude/versions/{cc_version}",
  "binary_must_contain": [
    "setTimeZone",
    "currentDate",
    "# Environment",
    "The user's email address is",
    "KSe(",
    "eca("
  ],
  "go_sentinels": [
    {
      "path": "backend/internal/service/gateway_request_tk_cc_prompt_surface.go",
      "must_contain": [
        "func tkNormalizeAnthropicCCPromptSurface",
        "func tkStripCCEnvironmentSection",
        "func tkNormalizeCCUserEmailLine"
      ]
    },
    {
      "path": "backend/internal/service/gateway_anthropic_request_normalize_tk.go",
      "must_contain": [
        "func tkApplyAnthropicCCPromptSurfaceNormalize"
      ]
    },
    {
      "path": "backend/internal/service/account_tk_oauth_email.go",
      "must_contain": [
        "func (a *Account) GetOAuthAccountEmail"
      ]
    }
  ]
}
