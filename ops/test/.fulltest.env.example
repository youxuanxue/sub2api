# TokenKey 全平台×全模态测试 —— 环境变量样例
# 复制为 ops/test/.fulltest.env（被 .gitignore 的 *.env 规则忽略，不会入库），按需填写。
# 脚本启动时会自动 source 同目录的 .fulltest.env。

# 必填：universal key（routing_mode=universal 的 key；本机持有，绝不入库）
TK_FULLTEST_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# 目标网关（默认 prod）
TK_FULLTEST_BASE_URL=https://api.tokenkey.dev

# 单请求超时秒数（image/video/responses 偏慢，默认 90）
TK_FULLTEST_TIMEOUT=90

# kiro 直连 key：kiro 与 anthropic 共享 claude-* 命名空间，universal key 无法定向到 kiro，
# 需一把绑 kiro 组的 direct key。缺省则 kiro 行 SKIP。
TK_FULLTEST_KIRO_KEY=

# 代表模型覆盖（换成你账号实际在册/已授权的模型名；不改则用脚本内置默认）
TK_FULLTEST_MODEL_ANTHROPIC_TEXT=claude-sonnet-4-6
TK_FULLTEST_MODEL_OPENAI_TEXT=gpt-5.1
TK_FULLTEST_MODEL_OPENAI_RESPONSES=gpt-5.1
TK_FULLTEST_MODEL_OPENAI_IMAGE=gpt-image-1
TK_FULLTEST_MODEL_GEMINI_TEXT=gemini-2.5-flash
TK_FULLTEST_MODEL_GEMINI_IMAGE=imagen-4.0-fast-generate-001
TK_FULLTEST_MODEL_GEMINI_VIDEO=veo-3.1-generate-001
TK_FULLTEST_MODEL_ANTIGRAVITY_TEXT=gemini-3-flash-agent
TK_FULLTEST_MODEL_NEWAPI_TEXT=deepseek-chat
TK_FULLTEST_MODEL_NEWAPI_IMAGE=doubao-seedream-4-0-250828
TK_FULLTEST_MODEL_NEWAPI_VIDEO=doubao-seedance-2-0-260128
TK_FULLTEST_MODEL_GROK_TEXT=grok-4
TK_FULLTEST_MODEL_KIRO_TEXT=claude-sonnet-4-6
