# .cursor/cloud-agent.env — declarative runtime contract for sub2api Cursor agents.
#
# Sourced by `dev-rules/templates/cloud-agent-bootstrap.sh` (cloud + local).
# This file declares WHAT the agent needs; HOW to install it lives in
# dev-rules. See `dev-rules/templates/cloud-agent.env.example` for the full
# shape and field documentation.

# Tools the agent's runtime depends on.
#   claude  — Claude Code CLI (auto-installed via npm)
#   gh      — GitHub CLI (used by scripts/fetch-prod-{logs,error-clusters}.sh
#             when GH_TOKEN is set; auto-installed via apt/brew)
#   jq      — JSON processor (used by the same fetch scripts; auto-installed)
CLOUD_AGENT_TOOLS="claude gh jq"

# Secrets that MUST be present.
#   ANTHROPIC_AUTH_TOKEN — TokenKey gateway token consumed by Claude Code CLI.
#   Configure in: Cursor Dashboard → Cloud Agents → Secrets (cloud) or
#   shell rc / direnv (local).
CLOUD_AGENT_REQUIRED_SECRETS="ANTHROPIC_AUTH_TOKEN"

# Secrets that unlock optional capabilities (warn-only when missing).
#   GH_TOKEN — fine-grained PAT for youxuanxue/sub2api with
#              actions:read/write + contents:read. Unlocks
#              scripts/fetch-prod-{logs,error-clusters}.sh.
#              See deploy/aws/README.md "Cloud Agent 拉取 ..." sections.
#   TK_TOKEN — user API key (sk-...) for scripts/tk_gateway_smoke.sh gateway steps.
CLOUD_AGENT_OPTIONAL_SECRETS="GH_TOKEN TK_TOKEN"

# Self-hosted Claude Code gateway URL.
#   Pair with CLOUD_AGENT_CLAUDE_TOKEN_VAR=ANTHROPIC_AUTH_TOKEN (the default).
#   The bootstrap writes a minimal ~/.claude/settings.json with these two
#   keys; the project hook below then rewrites it with the same two keys
#   plus TokenKey-opinionated runtime knobs (effortLevel,
#   MAX_THINKING_TOKENS, …). Keeping BASE_URL declared here lets
#   `cloud-agent-bootstrap.sh --check` verify the file points at the
#   right gateway without the project hook having to re-implement
#   verification.
CLOUD_AGENT_CLAUDE_BASE_URL="https://api.tokenkey.dev"
CLOUD_AGENT_CLAUDE_TOKEN_VAR="ANTHROPIC_AUTH_TOKEN"

# Project-specific bootstrap hook.
#   Runs AFTER the generic install + env check. Handles:
#     - sibling new-api repo sync (CLAUDE.md §4)
#     - frontend pnpm install
#     - TokenKey-opinionated ~/.claude/settings.json rewrite
#     - prod-data fetch self-test (GH_TOKEN guarded)
#     - preflight + make test sanity (non-blocking)
CLOUD_AGENT_PROJECT_HOOK="bash .cursor/cloud-agent-project-hook.sh"
