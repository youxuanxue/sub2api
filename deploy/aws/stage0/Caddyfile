# tokenkey · AWS Stage 0 · Caddyfile
# -----------------------------------------------------------------------------
# Cloud-Init 会用 envsubst 把 ${API_DOMAIN}/${ACME_EMAIL} 替换为实际值。
# Caddy 容器启动后会通过 HTTP-01 自动申请并续签 Let's Encrypt 证书。
# -----------------------------------------------------------------------------

{
	email ${ACME_EMAIL}
	# 取消下一行注释可改用 staging（联调时避免触发 LE 速率限制）
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

${API_DOMAIN} {
	encode zstd gzip

	@static {
		path /assets/*
		path /logo.png
		path /favicon.ico
	}
	header @static ?Cache-Control "public, max-age=31536000, immutable"

	# Per-IP rate limit (github.com/mholt/caddy-ratelimit — baked into the custom
	# image referenced by docker-compose.yml; stock caddy can't parse this).
	# WHY: a single source flooding one model with an empty account pool drove a
	# 503 + retry storm (one IP peaked 1540 RPM = 62% of 24h traffic). This caps
	# any one client at the cheapest layer, before auth/DB/scheduling, and returns
	# 429 (clients back off) instead of melting the node.
	# THRESHOLD 500 req / 60s: data-justified — across 88 prod IPs over 24h the
	# legit peak-RPM p95 was 71; 500 sits ~7x above it (wide false-positive margin
	# for bursty legit clients) and still crushes the 1540-RPM flood outlier.
	# `key {remote_host}` = real client IP (Caddy already overwrites
	# X-Forwarded-For with {remote_host}). Sliding-window; the module orders
	# `rate_limit` before reverse_proxy by default — no `order` needed.
	rate_limit {
		zone per_ip {
			key    {remote_host}
			window 1m
			events 500
		}
	}

	tls {
		protocols tls1.2 tls1.3
	}

	reverse_proxy tokenkey:8080 {
		flush_interval -1
		# Active health 走 /health（drain-aware）：SIGUSR1 → /health=503 →
		# Caddy active 立刻把 upstream 摘除，发版排空窗口期间 0 新流量打到老
		# 容器。注意：docker healthcheck 用 /health/live（不受 drain 影响），
		# 避免 drain 触发 docker 自动 restart；Caddy active health 没有 auto-
		# restart 副作用，只决定要不要继续转发，所以 drain-aware 是正确选择。
		health_uri /health
		health_interval 5s
		health_timeout 3s
		# Passive health（top-level，不能放进 sub-block）：覆盖 stop→start 短暂
		# 真空期里 dial 失败 / 502 / gateway-timeout 504 的场景。
		# 故意 NOT 含 503：app 的 503（no available accounts / overloaded）是
		# 应用层的合法响应，不代表后端进程坏了。单上游下，因一个 503 把唯一后端
		# 标 unhealthy 零 failover 收益（无处可转），只会让后续请求落进
		# lb_try_duration 干等 30s——一个 per-request 503 被放大成全节点停摆
		# （503 风暴时每个 503 重新点燃 5s unhealthy 窗，后端持续 down）。真宕机
		# 仍由 502/504 兜住；发版排空走 active health（drain → /health=503），与
		# 被动 unhealthy_status 无关，不受影响。
		fail_duration 5s
		max_fails 1
		unhealthy_status 502 504
		# 落进 unhealthy 后，新请求在 Caddy 侧排队重试最多 30s，覆盖 stop→start
		# 的短真空期。曾抬到 120s 想盖住整个发版空窗（含 pre-drain ≤76s），但
		# lb_try_duration 对 Caddy 无差别：真宕机时它会把每个请求干等放大 4 倍、
		# 挂起连接堆积 ×4，瘦机器（t4g.small/micro）上可能反把 Caddy 拖垮。故回退
		# 30s 保「快速失败 + 不堆积」；发版空窗改由运维侧规避（闲时发版），根治走
		# blue-green（始终有健康容器，无空窗，届时 30s 也够）。
		lb_try_duration 30s
		lb_try_interval 1s
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		transport http {
			dial_timeout 5s
			keepalive 120s
			keepalive_idle_conns 64
			compression off
		}
	}

	request_body {
		max_size 100MB
	}

	log {
		output stdout
		format json
		level INFO
	}
}
