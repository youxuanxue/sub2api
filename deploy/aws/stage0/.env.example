# tokenkey · AWS Stage 0 · environment template
# -----------------------------------------------------------------------------
# 复制为 /var/lib/tokenkey/.env 并填入实际值。
# Cloud-Init 已为 POSTGRES_PASSWORD / JWT_SECRET / TOTP_ENCRYPTION_KEY 生成
# 随机值并写入；本文件用于本地开发或手工调整时参考。
# -----------------------------------------------------------------------------

# 对外域名（Caddy 会用它申请 LE 证书；DNS A 记录必须先指向 EC2 EIP）
API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com

# 时区（影响日志、统计、订阅过期）
TZ=UTC

# 运行模式
SERVER_MODE=release
RUN_MODE=standard

# 应用镜像（GHCR 私仓 / 公仓均可）
# - 生产（CFN 部署）：由 Cloud-Init 从 GhcrOwner / ImageTag 参数拼出后写入，**无需本文件**
# - 本地 docker compose up 调试：把 <owner> 换成你自己的 GitHub 用户/组织名
#   推荐固定不可变 tag：ghcr.io/<owner>/sub2api:sha-<gitsha>
TOKENKEY_IMAGE=ghcr.io/<owner>/sub2api:main

# PostgreSQL（仅容器间访问，不暴露宿主机端口）
POSTGRES_USER=tokenkey
POSTGRES_PASSWORD=PLEASE_GENERATE_OPENSSL_RAND_HEX_24
POSTGRES_DB=tokenkey
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10

# Redis（仅容器间访问；如开启密码请同步设置 REDISCLI_AUTH 行为）
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10

# 管理员账号（首次启动自动创建）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# JWT / TOTP（必须固定值，否则重启后所有登录态/2FA 失效）
# 生成命令：openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRE_HOUR=1
TOTP_ENCRYPTION_KEY=
